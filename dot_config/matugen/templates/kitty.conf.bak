
active_tab_foreground {{ colors.surface.default.hex }}
active_tab_background {{ colors.primary.default.hex }}
inactive_tab_foreground {{ colors.primary.default.hex }}
inactive_tab_background {{ colors.primary_container.default.hex }}

# Tab title templates using the same colors
tab_title_template "{fmt.fg._{{ colors.primary_container.default.hex }}}{fmt.bg.default}{fmt.fg._{{ colors.primary.default.hex }}}{fmt.bg._{{ colors.primary_container.default.hex }}} {title.split()[0]} {fmt.fg._{{ colors.primary_container.default.hex }}}{fmt.bg.default} "
active_tab_title_template "{fmt.fg.{{ colors.primary.default.hex }}}{fmt.bg.default}{fmt.fg.{{ colors.surface.default.hex }}}{fmt.bg.{{ colors.primary.default.hex }}} {title.split()[0]} {fmt.fg.{{ colors.primary.default.hex }}}{fmt.bg.default} "


cursor            {{ colors.primary.default.hex }}
cursor_text_color {{ colors.on_primary.default.hex }}

foreground            {{ colors.on_surface.default.hex }}
background            {{ colors.surface_container_low.default.hex | saturate: 5.0, "hsl" | auto_lightness: 5.0 }}
selection_foreground  {{ colors.on_secondary.default.hex }}
selection_background  {{ colors.secondary.default.hex }}
url_color             {{ colors.secondary.default.hex }}

#: black 000000 767676
color0  {{ colors.surface.default.hex | saturate: 20.0, "hsl" | auto_lightness: 3.0 }}
color8  {{ colors.surface_container_highest.default.hex | harmonize: {{ colors.primary.default.hex }} | auto_lightness: 15.0 }}
#: red cc0403 f2201f
color1  {{ base16.base08.default.hex | harmonize: {{ colors.primary.default.hex }} | auto_lightness: 20.0 }}
color9  {{ base16.base08.default.hex | harmonize: {{ colors.primary.default.hex }} | auto_lightness: 20.0 }}
#: green 19cb00 23fd00
color2  {{ colors.secondary_fixed_dim.default.hex | harmonize: {{ colors.primary.default.hex }} | auto_lightness: 15.0 }}
color10 {{ colors.secondary_fixed.default.hex | harmonize: {{ colors.primary.default.hex }} | auto_lightness: 15.0 }}
#: yellow cecb00 fffd00
color3  {{ colors.tertiary_fixed_dim.default.hex | harmonize: {{ colors.primary.default.hex }} | auto_lightness: 15.0 }}
color11 {{ colors.tertiary_fixed.default.hex | harmonize: {{ colors.primary.default.hex }} | auto_lightness: 15.0 }}
#: blue 0d73cc 1a8fff
color4  {{ colors.on_tertiary_fixed_variant.default.hex | harmonize: {{ colors.primary.default.hex }} | auto_lightness: 15.0 }}
color12 {{ colors.tertiary.default.hex | harmonize: {{ colors.primary.default.hex }} | auto_lightness: 15.0 }}
#: magenta cb1ed1 fd28ff
color5  {{ colors.on_secondary_fixed_variant.default.hex | harmonize: {{ colors.primary.default.hex }} | auto_lightness: 15.0 }}
color13 {{ colors.secondary.default.hex | harmonize: {{ colors.primary.default.hex }} | auto_lightness: 15.0 }}
#: cyan 0dcdcd 14ffff
color6  {{ colors.on_primary_fixed_variant.default.hex | auto_lightness: 20.0 }}
color14 {{ colors.primary.default.hex | auto_lightness: 20.0 }}
#: white dddddd ffffff
color7  {{ colors.on_surface_variant.default.hex | auto_lightness: 15.0 }}
color15 {{ colors.on_surface.default.hex | saturate: 40.0, "hsl" }}

color0:  {{ colors.surface_container_low.default.hex | saturate: 15.0, "hsl" | lighten: -3.0 }}
color15: {{ colors.on_surface.default.hex | saturate: 40.0, "hsl" }}

